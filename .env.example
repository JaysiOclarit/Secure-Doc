# Supabase Configuration
# Get these values from https://supabase.com/dashboard/project/[PROJECT_ID]/settings/api

# Public API URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Public Anonymous Key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# (Optional) Service Role Key - NEVER expose to frontend, only use in backend/edge functions
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
